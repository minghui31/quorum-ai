# Copy to .env — Quorum runs with ZERO keys (mock mode), but real keys make it real.

# Option 1 (best quality): Anthropic
ANTHROPIC_API_KEY=
# QUORUM_MODEL=claude-sonnet-5

# Option 2 (any OpenAI-compatible API — OpenAI, DeepSeek, Qwen, local vLLM/ollama):
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# QUORUM_MODEL=deepseek-chat

# Force a backend: anthropic | openai | camel | mock
# QUORUM_BACKEND=

# Cost guard (default 7)
# QUORUM_MAX_COUNCILORS=7
